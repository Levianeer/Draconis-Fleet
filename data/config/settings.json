{
	# ========================================
	# SYSTEM TOGGLES
	# ========================================

	"draconisEnableAICoreRaids": true,					# Enable/disable AI core raids on faction markets	#	Default : true
	"draconisEnableRemnantRaids": true,					# Enable/disable raids on Remnant installations	#	Default : true
	"draconisEnableWeaponEscalation": true,				# Replace Draconis Halberd/Naginata loadouts with Daikyu-class when player fields whitelisted nuclear weapons	#	Default : true

	# ========================================
	# SHADOW FLEET PATROLS
	# ========================================
	# These are the roaming hostile fleets that spawn in systems with player markets
	# Formula: difficulty = Base + round(MarketPresence × Multiplier)

	"draconisPatrolDifficultyBase": 4,					# Base patrol difficulty	#	Default : 4
	"draconisPatrolDifficultyMult": 4.0,				# Patrol difficulty scaling with market presence	#	Default : 4.0
	"draconisMaxFleets": 9,								# Maximum concurrent patrols per system	#	Default : 9
	"draconisSpawnFrequencyMult": 45.0,					# Spawn frequency multiplier (higher = more frequent spawns, competes with other factions)	#	Default : 45.0

	# ========================================
	# PUNITIVE EXPEDITIONS (COLONY CRISIS)
	# ========================================
	# These settings control the raid fleets that spawn during the Colony Crisis event
	# Formula: difficulty = FleetSizeMult × Base × (MinFactor + MaxFactor × MarketPresence)

	# --- Timing ---
	"draconisExpeditionEventFrequency": 5.0,			# Likelihood the crisis triggers (lower = less likely)	#	Default : 5.0
	"draconisExpeditionPrepDaysMin": 14.0,				# Minimum days to prepare expedition	#	Default : 14.0
	"draconisExpeditionPrepDaysVariance": 14.0,			# Random variance (0 to this value) added to prep days	#	Default : 14.0
	"draconisExpeditionPayloadDaysMin": 27.0,			# Minimum days for expedition to travel/operate	#	Default : 27.0
	"draconisExpeditionPayloadDaysVariance": 7.0,		# Random variance (0 to this value) added to travel days	#	Default : 7.0

	# --- Strength ---
	"draconisExpeditionDifficultyBase": 7.0,			# Base strength multiplier	#	Default : 7.0
	"draconisExpeditionDifficultyMinFactor": 1.0,		# Minimum difficulty factor (always applied)	#	Default : 1.0
	"draconisExpeditionDifficultyMaxFactor": 4.0,		# Maximum difficulty factor (scales with player presence)	#	Default : 4.0

	# --- Defeat-scaled difficulty bounds --- (replaces draconisExpeditionMinTotalDifficulty / Max)
	"draconisExpeditionDiffMin1": 28,					# Expedition 1 - minimum total difficulty (floor, always fires) - targets ~4 QUALITY+SMOD_3 fleets, ≈ TT merc attack	#	Default : 28
	"draconisExpeditionDiffMax1": 44,					# Expedition 1 - maximum total difficulty cap - cap at ~5 fleets	#	Default : 44
	"draconisExpeditionDiffMin2": 38,					# Expedition 2 - minimum total difficulty - targets ~5 fleets (midpoint TT->Remnant)	#	Default : 38
	"draconisExpeditionDiffMax2": 54,					# Expedition 2 - maximum total difficulty cap - cap at ~6 fleets	#	Default : 54
	"draconisExpeditionDiffMin3": 46,					# Expedition 3 - minimum total difficulty - targets ~6 fleets, ≈ Remnant nexus attack	#	Default : 46
	"draconisExpeditionDiffMax3": 64,					# Expedition 3 - maximum total difficulty cap - cap at ~7 fleets	#	Default : 64

	# --- Post-defeat tracker reset floors ---
	"draconisExpeditionReset1": 50,						# Tracker value after first defeat (mid-ACTIVE_MEASURES)	#	Default : 50
	"draconisExpeditionReset2": 65,						# Tracker value after second defeat (low-LIABILITY)	#	Default : 65

	# ========================================
	# AIO TRACKER (COLONY CRISIS)
	# ========================================
	# The Alliance Intelligence Officer Tracker - the primary DDA crisis mechanic.
	# Advances monthly based on player AI core usage and DDA relations.
	# Commission pauses the tracker. Defeating the invasion at 100 resets it and grants a reward.

	# --- Monthly increment formula ---
	# increment = max(baseFloor, aiCoreContrib * relationsMultiplier)
	# aiCoreContrib = sum(weightedCores per market) * aiCoreRate   (Alpha=3, Beta=2, Gamma=1, Admin=1)
	# relationsMultiplier = 1 - clamp(ddaRelation, 0, 1) * relationsMaxReduction

	"draconisAIOBaseFloor": 0.5,						# Minimum increment per month - never zero while crisis is active	#	Default : 0.5
	"draconisAIOAICoreRate": 0.4,						# Increment per weighted AI core per month	#	Default : 0.4
	"draconisAIOProgressUnit": 10,					# Diminishing-returns unit for AI core contrib (matching Hegemony)	#	Default : 10
	"draconisAIOProgressMult": 0.75,				# Decay factor per unit (matching Hegemony)		#	Default : 0.75
	"draconisAIORelationsMaxReduction": 0.7,			# Max fraction by which high DDA rep can reduce the increment (0.7 = 70% reduction at max rep)	#	Default : 0.7

	# --- Shadow fleet scaling ---
	"draconisAIOMaxFleetMagnitude": 4.0,				# Maximum shadow fleet magnitude at tracker = 100 (linearly scales from 34->100)	#	Default : 4.0

	# --- Colony debuffs (applied to ALL player markets) ---
	# Accessibility: linear 0->100 maps to 0->max (e.g. 50 pts = 25%, 100 pts = 50%)
	# Stability: scales 15->25 to 0->max, capped at max after tracker = 25
	"draconisAIOMaxAccessibilityPenalty": 0.5,			# Maximum accessibility penalty (0.50 = -50%)	#	Default : 0.5
	"draconisAIOMaxStabilityPenalty": 2.0,				# Maximum stability penalty (flat)	#	Default : 2.0

	# --- AI core industry disruption (tracker >= 25, one random industry at a time) ---
	"draconisAIODisruptionDaysMin": 12.0,				# Disruption duration at progress=25 (shortest)	#	Default : 12.0
	"draconisAIODisruptionDaysMax": 60.0,				# Disruption duration at progress=100 (longest)	#	Default : 60.0
	"draconisAIODisruptionCooldownMin": 7.0,			# Minimum days between disruptions	#	Default : 7.0
	"draconisAIODisruptionCooldownMax": 45.0,			# Maximum days between disruptions	#	Default : 45.0

	# --- One-time factors (combat & donation) ---
	"draconisAIOCombatHostilePoints": 5,				# Tracker increase when player fights any DDA/XLII fleet	#	Default : 5
	"draconisAIOCombatShadowPoints": 3,					# Tracker increase when player defeats a shadow fleet (AIO notes capability)	#	Default : 3
	"draconisAIODonationAlphaPoints": -15,				# Tracker reduction per Alpha core donated to DDA	#	Default : -15
	"draconisAIODonationBetaPoints": -10,				# Tracker reduction per Beta core donated to DDA	#	Default : -10
	"draconisAIODonationGammaPoints": -5,				# Tracker reduction per Gamma core donated to DDA	#	Default : -5

	# --- Periodic payment (bar event) ---
	# Recurring monthly arrangement offered by DDA intelligence contact at player-owned colony bars.
	# Monthly cost = baseCost * max(1, sum of AI core weights across player colonies).
	# Core weights: gamma = 1x, beta = 2x, alpha = 3x. Minimum charge is 1x base (no cores deployed).
	"draconisAIOPaymentCost": 2500,					# Base cost unit per AI core weight	#	Default : 2500

	# --- Rewards ---
	# Beating the invasion at 100 gives you this buff to production
	"draconisArmamentsExportBonus": 0.25,				# Heavy armaments export bonus after defeating expedition (25% = 0.25)	#	Default : 0.25

	# ========================================
	# AI CORE THEFT SYSTEM
	# ========================================
	# Successful Draconis raids will attempt to steal AI cores from colonies

	"draconisAICoreTheft": { # Configuration for Draconis AI core theft system
		"factionCoreChances": { # Chance to find/steal cores from factions that should have them lore-wise
			"tritachyon": { # Tri-Tachyon: High-tech faction, likely to have AI cores
				"alphaChance": 0.15,
				"betaChance": 0.35,
				"gammaChance": 0.50,
				"minMarketSize": 5
			},
			"hegemony": { # Hegemony: Anti-AI but might have captured/confiscated cores
				"alphaChance": 0.05,
				"betaChance": 0.20,
				"gammaChance": 0.40,
				"minMarketSize": 6
			},
			"persean": { # Persean League: Moderate tech level
				"alphaChance": 0.05,
				"betaChance": 0.15,
				"gammaChance": 0.35,
				"minMarketSize": 5
			},
			"diktat": { # Sindrian Diktat: Wealthy, likely to have some cores
				"alphaChance": 0.08,
				"betaChance": 0.20,
				"gammaChance": 0.40,
				"minMarketSize": 5
			},
			"independent": { # Independent: Variable, some might have cores
				"alphaChance": 0.02,
				"betaChance": 0.10,
				"gammaChance": 0.25,
				"minMarketSize": 5
			},
			"player": { # Player always uses actual installed cores, never fallback
				"alphaChance": 0.0,
				"betaChance": 0.0,
				"gammaChance": 0.0,
				"minMarketSize": 99
				}
			},
		"fallbackBehavior": { # Fallback enabled - prefer actual cores, generate fallback if none found
			"maxCoresPerRaid": 3,
			"preferActualCores": true
		},
		"stolenCoreDestination": { # Larger Draconis markets are more likely to receive stolen cores
			"preferLargeMarkets": true,
			"marketSizeWeight": 2.0
		}
	},

	# ========================================
	# DRACON - DRACONIS READINESS CONDITION
	# ========================================
	# Dynamic threat-based condition applied to all DDA markets.
	# Calculates a threat score (0-100) monthly and maps to DRACON levels 5 (peace) to 1 (total war).
	# Higher levels grant military buffs at increasing economic cost.
	# Requires Nexerelin - without Nex, markets use Steel Curtain instead.

	"draconisReadinessCondition": {
		"enabled": true,							# Enable/disable DRACON system (falls back to Steel Curtain if disabled)	#	Default : true
		"testLevelOverride": -1,					# DEBUG: Force a specific DRACON level (-1 = disabled, 1-5 = forced level)	#	Default : -1

		"factorWeights": {							# How much each threat factor contributes to the score
			"warScorePerWar": 10,					# Points per faction at war with DDA	#	Default : 10
			"lostColonyScore": 50,					# Points per baseline market lost	#	Default : 25
			"unstableMarketScore": 10,				# Points per unstable DDA market (stability <= threshold)	#	Default : 10
			"maxFleetWeaknessScore": 10,			# Maximum points from fleet weakness ratio	#	Default : 10
			"invasionPressureScore": 25				# Points if invasion/raid fleet targets DDA (binary)	#	Default : 25
		},
		"decayRates": {								# Monthly score decay (negative values)
			"peacetimeDecay": -10,					# Decay when DDA is at peace	#	Default : -10
			"wartimeDecay": -5						# Decay when DDA is at war	#	Default : -5
		},
		"thresholds": {								# Score thresholds for DRACON levels (score >= threshold = that level)
			"level4Min": 25,						# DRACON 4	#	Default : 25
			"level3Min": 50,						# DRACON 3	#	Default : 50
			"level2Min": 75,						# DRACON 2	#	Default : 75
			"level1Min": 90							# DRACON 1	#	Default : 90
		},
		"instabilityThreshold": 3,					# Markets with base stability at or below this are counted as unstable	#	Default : 3
		"checkIntervalDays": 14,					# How often to recalculate (in days)	#	Default : 14
		"activeCrisisBonus": 25						# Per-stage bonus added to threat score while AIO Tracker crisis is active (×1/×2/×3 for each invasion stage)	#	Default : 25
	},

	# ========================================
	# AI CORE FLEET SCALING
	# ========================================
	# Draconis gradually uses more AI cores in their fleets as the game progresses
	# AI cores only fill empty officer slots (does NOT replace human officers)

	"draconisAICoreScaling": {
		"enabled": true,						# Enable/disable AI core fleet scaling	#	Default : true
		"testCycleOverride": -1,				# DEBUG: Override game cycle for testing (-1 = disabled, X = test at that cycle)	#	Default : -1
		"recheckIntervalDays": 30.0,			# How often to recheck fleets for new empty slots (in days)	#	Default : 30.0

		# Cycle thresholds defining the scaling curve
		# NOTE: Starsector campaigns start at cycle ~206, so these are absolute cycle numbers
		"cycleThresholds": {
			"earlyGameEnd": 208,				# No AI cores before this cycle	#	Default : 208
			"midGameStart": 208,				# Start adding AI cores			#	Default : 208
			"midGameEnd": 213,					# Transition point				#	Default : 213
			"lateGameStart": 213,				# More AI cores begin appearing	#	Default : 213
			"lateGameEnd": 221,					# Heavy AI core usage			#	Default : 221
			"endGameStart": 221,				# Very heavy usage begins		#	Default : 221
			"endGameEnd": 231					# Maximum saturation			#	Default : 231
		},

		# Coverage percentages (how many empty officer slots to fill with AI cores)
		"coveragePercentages": {
			"earlyGame": 0.1,					# 10% at cycle 206-208		#	Default : 0.1
			"midGame": 0.25,					# 25% at cycle 208-213		#	Default : 0.25
			"lateGame": 0.75,					# 75% at cycle 213-221		#	Default : 0.75
			"endGame": 1.0						# 100% at cycle 221+		#	Default : 1.0
		},

		# Core type distribution weights (interpolated between milestones)
		"coreTypeWeights": {
			"earlyMidGame": {					# Only Gamma cores
				"gamma": 1.0,
				"beta": 0.0,
				"alpha": 0.0
			},
			"midGame": {						# Still only Gamma
				"gamma": 0.9,
				"beta": 0.1,
				"alpha": 0.0
			},
			"midLateGame": {					# Mostly Gamma, some Beta
				"gamma": 0.75,
				"beta": 0.2,
				"alpha": 0.05
			},
			"lateGame": {						# Mix of all types
				"gamma": 0.5,
				"beta": 0.4,
				"alpha": 0.1
			},
			"endGame": {						# Full distribution
				"gamma": 0.25,
				"beta": 0.5,
				"alpha": 0.25
			}
		}
	},

